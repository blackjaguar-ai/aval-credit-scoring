# AVAL — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA se commitea .env al repositorio. .gitignore ya lo excluye.

# LLM para la capa agéntica
OPENAI_API_KEY=sk-...

# Entorno de ejecución
ENVIRONMENT=development  # development | production

# Logging
LOG_LEVEL=INFO